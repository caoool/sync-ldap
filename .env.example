# ─── LDAP ─────────────────────────────────────────────────────────
# Shared by the openldap container and wecom-ldap-sync service.
# LDAP_HOST should be "openldap" when running in Docker Compose,
# or "127.0.0.1" when running the sync service locally.
# Organization name shown in LDAP
LDAP_ORGANISATION=mycompany
# Domain for LDAP (used by openldap container to derive base DN)
LDAP_DOMAIN=ldap.example.com
# Base DN — must match LDAP_DOMAIN (e.g. ldap.example.com → dc=ldap,dc=example,dc=com)
LDAP_BASE_DN=dc=ldap,dc=example,dc=com
# LDAP admin password — change this!
LDAP_ADMIN_PASSWORD=changeme
LDAP_TLS=false
# Auto-handled: defaults to 127.0.0.1 for local dev;
# overridden to "openldap" by compose.yml in Docker.
LDAP_HOST=127.0.0.1
LDAP_PORT=389
# Admin bind DN — must match your base DN
LDAP_ADMIN_DN=cn=admin,dc=ldap,dc=example,dc=com
# OU under base DN where synced users are placed
LDAP_USER_OU=people
# Default password assigned to new LDAP users (SSHA-hashed).
# Only set on user creation; existing passwords are not overwritten.
# Users without a password will also receive this on the next sync.
LDAP_DEFAULT_PASSWORD=changeme

# ─── Email ────────────────────────────────────────────────────────
# Generate email as uid + suffix (e.g. "@example.com" → CaoLu@example.com)
# Leave blank to skip email generation (WeCom email used if available)
EMAIL_SUFFIX=@example.com

# ─── WeCom (企业微信自建应用) ─────────────────────────────────────
# Create a self-built app in WeCom Admin Console (企业微信管理后台):
#   应用管理 → 自建 → Create an app
# Grant the app "通讯录读取" (contacts read) permission, then:
#   Corp ID:  我的企业 → 企业信息 → 企业ID
#   Secret:   自建应用 → 应用详情 → Secret
# Make sure your server IP is added to the app's trusted IP list.
WECOM_CORPID=your_corp_id
WECOM_CORPSECRET=your_app_secret

# ─── Sync options ─────────────────────────────────────────────────
# How often to re-sync (minutes)
SYNC_INTERVAL_MINUTES=30
# Delete LDAP users that no longer exist in WeCom (use with caution)
SYNC_DELETE_ORPHANS=true
# Set to true to preview changes without writing to LDAP
DRY_RUN=false
